{
  "imports": {
    "@/": "./src/",
    "camelcase-keys": "npm:camelcase-keys@^9.1.3",
    "dice-roller": "npm:@dice-roller/rpg-dice-roller@5.5.1",
    "discord": "npm:discordeno@^18.0.1",
    "hono": "npm:hono@^4.7.10",
    "zod": "npm:zod@^3.25.32",
    "zod-error": "npm:zod-error@^1.5.0"
  },
  "tasks": {
    "dev": "deno run --unstable --allow-import=deno.land,unpkg.com --allow-net=discord.com,gateway.discord.gg --allow-read=.env,.env.defaults,src/commands --env-file --allow-env --watch src/dev.ts",
    "prod": "deno run --unstable --allow-import=deno.land,unpkg.com --allow-net=discord.com,gateway.discord.gg,0.0.0.0:8000,api.deno.com,us-east4.txnproxy.deno-gcp.net --allow-read=.env,.env.defaults,src/commands --allow-env --watch src/prod.tsx",
    "run": "deno run --allow-read=.env,.env.defaults,src/commands --allow-import=deno.land,unpkg.com --allow-net=discord.com,gateway.discord.gg --allow-env",
    "regen-lock": "deno cache --reload --frozen=false --allow-import=deno.land,unpkg.com src/dev.ts src/prod.tsx",
    "cache-all": "deno cache --allow-import=deno.land,unpkg.com src/dev.ts src/prod.tsx",
    "check-all": "deno fmt && deno lint && deno check --allow-import=deno.land,unpkg.com src/**/*.ts tasks/**/*.ts test/**/*.ts"
  },
  "compilerOptions": {
    "jsx": "precompile",
    "jsxImportSource": "hono/jsx"
  }
}
