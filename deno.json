{
  "imports": {
    "@/": "./src/",
    "camelcase-keys": "npm:camelcase-keys@^10.0.2",
    "dice-roller": "npm:@dice-roller/rpg-dice-roller@5.5.1",
    "discord": "npm:discordeno@^21.0.0",
    "dd-cache-proxy": "npm:dd-cache-proxy@latest",
    "hono": "npm:hono@^4.12.15",
    "zod": "npm:zod@^4.3.6",
    "zod-error": "npm:zod-error@^2.0.0"
  },
  "tasks": {
    "dev": "deno run --unstable --allow-import=deno.land,unpkg.com --allow-net --allow-read=.env,.env.defaults,src/commands --env-file --allow-env --watch src/dev.ts --env-file",
    "prod": "deno run --unstable --allow-import=deno.land,unpkg.com --allow-net --allow-read=.env,.env.defaults,src/commands --allow-env --watch src/prod.tsx --env-file",
    "run": "deno run --allow-read=.env,.env.defaults,src/commands --allow-import=deno.land,unpkg.com --allow-net --allow-env --env-file",
    "regen-lock": "deno cache --reload --frozen=false --allow-import=deno.land,unpkg.com src/dev.ts src/prod.tsx",
    "cache-all": "deno cache --allow-import=deno.land,unpkg.com src/dev.ts src/prod.tsx",
    "check-all": "deno fmt && deno lint && deno check --allow-import=deno.land,unpkg.com src/**/*.ts tasks/**/*.ts test/**/*.ts"
  },
  "compilerOptions": {
    "jsx": "precompile",
    "jsxImportSource": "hono/jsx"
  }
}
